{
  "name": "@stria-icons/react",
  "version": "0.1.0",
  "description": "Stria Icons for React",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node ../../scripts/build-react.mjs"
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "keywords": [
    "icons",
    "svg",
    "stria",
    "react",
    "components"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/twinpath/stria-icons-react.git"
  },
  "dependencies": {
    "stria-icons": "workspace:*"
  }
}
